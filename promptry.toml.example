# promptry config
# Copy to promptry.toml in your project root

[storage]
# db_path = "~/.promptry/promptry.db"
# mode = "sync"                # sync | async | off

[tracking]
# sample_rate = 1.0            # fraction of track() calls that write (1.0 = all)
# context_sample_rate = 0.1    # fraction of track_context() calls (lower in prod)

[model]
# embedding_model = "all-MiniLM-L6-v2"
# semantic_threshold = 0.8

[monitor]
# interval_minutes = 1440   # how often to run (daily)
# threshold = 0.05          # flag if score drops more than 5%
# window = 30               # number of recent runs to look at
